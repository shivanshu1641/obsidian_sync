# ===============================
# Obsidian core artifacts
# ===============================

# Workspace / UI state (device-specific)
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Cache & temp files
.obsidian/cache
.obsidian/cache/*
.obsidian/plugins/**/cache

# Plugin runtime data (safe to ignore)
.obsidian/plugins/**/data.json
.obsidian/plugins/**/data/*.json

# ===============================
# Obsidian Git plugin
# ===============================

# Plugin logs / temp state
.obsidian/plugins/obsidian-git/logs
.obsidian/plugins/obsidian-git/temp

# ===============================
# Excalidraw artifacts
# ===============================

# Excalidraw backups (auto-generated)
.excalidraw-backups/
.excalidraw-cache/

# ===============================
# OS-level junk
# ===============================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Android / Samsung
Thumbs.db
*.bak
*.tmp

# ===============================
# Editor / tooling
# ===============================

.vscode/
.idea/

# ===============================
# Optional: large exports
# (uncomment if needed)
# ===============================

# *.mp4
# *.mov
# *.wav
.DS_Store
*workspace-mobile.json
*workspace.json
/.obsidian/plugins/obsidian-git/obsidian_askpass.sh
/.trash